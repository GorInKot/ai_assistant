# LLM-бэкенд: любой OpenAI-совместимый API.
# Прод (рекомендуется): Groq — бесплатный ключ на https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# Локальная альтернатива (Ollama): закомментируйте 3 строки выше и раскомментируйте эти:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b-instruct

# Rerank (0 экономит токены/лимиты бесплатного LLM-тарифа)
ENABLE_LLM_RERANK=0
RERANK_CANDIDATES=28
RERANK_TOP_N=16

# Секрет подписи JWT — задайте случайную строку:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# База знаний и логи
KB_ROOT=knowledge_base
LOG_FILE=logs/assistant.log
